[Unit]
Description=AutoHotspot - WiFi/USB/AP boot fallback
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/bin/autohotspot
RemainAfterExit=yes
TimeoutStartSec=60
StandardOutput=append:/var/log/autohotspot.log
StandardError=append:/var/log/autohotspot.log

[Install]
WantedBy=multi-user.target
